{
  "LocalRuntime": {
    "Portable": false
  },
  "Observability": {
    "Enabled": true,
    "Mode": "Advanced",
    "LogsPath": "runtime/app/logs",
    "MinimumLevel": "Information",
    "UseSeparateLogFiles": false,
    "EnableErrorLogs": true,
    "EnableSqlLogs": false,
    "EnableHttpLogs": true,
    "EnableDiagnosticEventLogs": false,
    "EnableDebugTrace": true,
    "RetainedFileCountLimit": 14
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
