{
  "AllowedHosts": "*",
  "Urls": "http://127.0.0.1:49321",
  "LocalRuntime": {
    "Portable": true,
    "DataPath": "runtime/app/data",
    "DatabasePath": "runtime/app/data/knowledge-app.db",
    "FilesPath": "runtime/app/files",
    "IndexPath": "runtime/app/indexes",
    "LogsPath": "runtime/app/logs"
  },
  "Ocr": {
    "Enabled": true,
    "EnginePath": "runtime/ocr/bin/tesseract.exe",
    "TessDataPath": "runtime/ocr/tessdata",
    "Languages": [ "ukr", "eng" ],
    "DetectLanguage": true,
    "MinimumImageWidth": 80,
    "MinimumImageHeight": 30
  },
  "Ai": {
    "Provider": "LlamaCpp",
    "BaseUrl": "http://127.0.0.1:11435",
    "ChatModel": "qwen2.5-3b-instruct",
    "EmbeddingModel": "BGE-M3",
    "Temperature": 0.2,
    "TopK": 40,
    "ContextSize": 8192,
    "AutoStartRuntime": true,
    "RuntimePath": "runtime/ai/bin/llama-server.exe",
    "ModelsPath": "runtime/ai/models"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [{ "Name": "Console" }]
  }
}
