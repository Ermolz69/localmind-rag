{
  "AllowedHosts": "*",
  "Urls": "http://127.0.0.1:49321",
  "LocalRuntime": {
    "Portable": true,
    "DataPath": "runtime/app/data",
    "DatabasePath": "runtime/app/data/knowledge-app.db",
    "FilesPath": "runtime/app/files",
    "IndexPath": "runtime/app/indexes",
    "LogsPath": "runtime/app/logs"
  },
  "Ocr": {
    "Enabled": true,
    "EnginePath": "runtime/ocr/bin/tesseract.exe",
    "TessDataPath": "runtime/ocr/tessdata",
    "Languages": [
      "ukr",
      "eng"
    ],
    "DetectLanguage": true,
    "MinimumImageWidth": 80,
    "MinimumImageHeight": 30
  },
  "IngestionWorker": {
    "Enabled": true,
    "PollIntervalSeconds": 2,
    "BatchSize": 1
  },
  "Ai": {
    "Provider": "LlamaCpp",
    "EmbeddingProvider": "LlamaCpp",
    "BaseUrl": "http://127.0.0.1:11435",
    "ChatBaseUrl": "http://127.0.0.1:11436",
    "EmbeddingBaseUrl": "http://127.0.0.1:11435",
    "ChatModel": "meta-llama/Llama-3.2-3B-Instruct",
    "ChatModelManifest": "llama-3.2-3b-instruct-q4-k-m",
    "EmbeddingModel": "bge-m3",
    "EmbeddingModelManifest": "bge-m3-q4-k-m",
    "Temperature": 0.2,
    "TopK": 40,
    "ContextSize": 8192,
    "AutoStartRuntime": true,
    "RuntimePath": "runtime/ai/bin/llama-server.exe",
    "ModelsPath": "runtime/ai/models",
    "RuntimeDownloadUrl": "https://github.com/ggml-org/llama.cpp/releases/download/b9222/llama-b9222-bin-win-vulkan-x64.zip"
  },
  "Rag": {
    "MinimumSourceScore": 0.3,
    "MaxSourceScoreDistance": 0.1,
    "EnableSemanticCache": false
  },
  "Observability": {
    "Enabled": true,
    "Mode": "Advanced",
    "LogsPath": "runtime/app/logs",
    "MinimumLevel": "Information",
    "EnableDebugTrace": false,
    "EnableRequestBodyLogging": false,
    "EnableResponseBodyLogging": false,
    "RetainedFileCountLimit": 14
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
