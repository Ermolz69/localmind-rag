KNOWLEDGE_APP_PORTABLE=true
LOCAL_API_URL=http://127.0.0.1:49321
LOCAL_STORAGE_PATH=runtime/app/files
LOCAL_DATABASE_PATH=runtime/app/data/knowledge-app.db
LOCAL_INDEX_PATH=runtime/app/indexes

AI_PROVIDER=LlamaCpp
AI_BASE_URL=http://127.0.0.1:11435
AI_CHAT_MODEL=qwen2.5-3b-instruct
AI_EMBEDDING_MODEL=nomic-embed-text
AI_TEMPERATURE=0.2
AI_TOP_K=40
AI_CONTEXT_SIZE=8192
AI_AUTO_START=true
AI_RUNTIME_PATH=runtime/ai/bin/llama-server.exe
AI_MODELS_PATH=runtime/ai/models

SYNC_ENABLED=false
