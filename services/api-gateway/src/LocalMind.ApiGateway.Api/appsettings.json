{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AuthService": {
    "BaseUrl": "http://localhost:3001",
    "Issuer": "localmind-auth",
    "Audience": "localmind-clients"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "files-route": {
        "ClusterId": "file-cluster",
        "Match": {
          "Path": "/api/files/{**catch-all}"
        }
      },
      "folders-route": {
        "ClusterId": "file-cluster",
        "Match": {
          "Path": "/api/folders/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:3001/"
          }
        }
      },
      "file-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8080/"
          }
        }
      }
    }
  }
}
