#!/usr/bin/env sh
set -eu

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "[pre-commit] Checking repository formatting..."
(cd backend && dotnet restore KnowledgeApp.slnx && dotnet format KnowledgeApp.slnx --verify-no-changes --no-restore)
pnpm --filter desktop format:check
echo "[pre-commit] Formatting checks passed."
